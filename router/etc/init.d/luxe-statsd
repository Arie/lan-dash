#!/bin/sh /etc/rc.common
# luxe-statsd — stats collector for the LuxeLAN start page (http://luxe).
# Writes JSON snapshots to /tmp/luxe/, served by the "luxe" uhttpd instance.

START=95
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/luxe-statsd
    procd_set_param respawn 3600 5 0
    procd_set_param stderr 1
    procd_close_instance
}
