#!/bin/sh /etc/rc.common
# luxe-pinger — WAN latency sampler for the LuxeLAN start page ping graph.

START=95
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/luxe-pinger
    procd_set_param respawn 3600 5 0
    procd_set_param stderr 1
    procd_close_instance
}
